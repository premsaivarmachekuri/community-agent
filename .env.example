# Slack bot (required for bot functionality)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret

# Redis for Chat SDK conversation state (required for bot functionality)
REDIS_URL=redis://your-redis-url

# AI provider (required for bot functionality — pick one)
# Option 1: AI Gateway (recommended on Vercel — auto-authenticated via OIDC in production)
AI_GATEWAY_API_KEY=your-gateway-api-key
# Option 2: Direct Anthropic API key
# ANTHROPIC_API_KEY=your-anthropic-key

# Upstash Redis for admin panel data (optional — falls back to mock data)
# Set ONE pair — either UPSTASH_* (from console.upstash.com) or KV_* (from Vercel Marketplace).
# Vercel Marketplace creates several env vars; only these two are needed:
#   KV_REST_API_URL   → use for UPSTASH_REDIS_REST_URL
#   KV_REST_API_TOKEN → use for UPSTASH_REDIS_REST_TOKEN (NOT the READ_ONLY token)
# UPSTASH_REDIS_REST_URL=https://your-upstash-url
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Admin panel authentication (required — run `npx auth@latest migrate` after setting these)
# SLACK_CLIENT_ID and SLACK_CLIENT_SECRET: from the same Slack app → Basic Information → App Credentials
# SLACK_TEAM_ID: restricts sign-in to your workspace (find it in the workspace URL: app.slack.com/client/T.../...)
BETTER_AUTH_SECRET=your-secret-min-32-chars
# BETTER_AUTH_URL=http://localhost:3000
SLACK_CLIENT_ID=your-slack-app-client-id
SLACK_CLIENT_SECRET=your-slack-app-client-secret
SLACK_TEAM_ID=T0EXAMPLE
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Savoir knowledge base (optional — enables bash file search tools)
# Deploy a knowledge-agent-template instance and point to it:
# SAVOIR_API_URL=https://your-savoir-instance.vercel.app
# SAVOIR_API_KEY=your-savoir-api-key

# Web search domain scoping (optional — restricts web search to these domains)
# SEARCH_DOMAINS=community-site.com,docs.partner.com

# Community lead flagging (optional — bot can escalate tricky issues via Slack DM)
# COMMUNITY_LEAD_SLACK_ID=U0EXAMPLE

# Customization (optional)
# COMMUNITY_NAME=Your Community
# AI_MODEL=anthropic/claude-sonnet-4-20250514
# SLACK_WORKSPACE_URL=https://your-workspace.slack.com
